{% extends 'tax_extractor/base.html' %}

{% block title %}Extraction Results{% endblock %}

{% block content %}

<div class="bg-white rounded-xl shadow-lg p-8">

<div class="flex justify-between items-center mb-6">
    <div>
        {% if taxpayer_name %}
            <h2 class="text-3xl font-bold text-gray-800 mb-2">{{ taxpayer_name }}</h2>
        {% else %}
            <h2 class="text-3xl font-bold text-gray-800 mb-2 text-red-600">[Missing Taxpayer Info]</h2>
        {% endif %}

        {% if current_year and previous_year %}
            <p class="mt-2 text-blue-600 font-medium">
                Tax Year: {{ current_year }} (Previous: {{ previous_year }})
            </p>
        {% endif %}
    </div>

    <div class="flex gap-2">
        <button onclick="showEmailModal()"
                class="inline-flex items-center gap-2 px-4 py-2 bg-blue-600 text-white font-semibold rounded-lg hover:bg-blue-700 hover:-translate-y-0.5 hover:shadow-lg hover:shadow-blue-600/30 transition-all">
            <span>Send Email</span>
        </button>

        <a href="{% url 'download_pdf' document.id %}"
           class="inline-flex items-center gap-2 px-4 py-2 bg-purple-600 text-white font-semibold rounded-lg hover:bg-purple-700 hover:-translate-y-0.5 hover:shadow-lg hover:shadow-purple-600/30 transition-all no-underline">
            <span>📄 Download PDF</span>
        </a>

        <a href="{% url 'view_summary' document.id %}"
           class="inline-flex items-center gap-2 px-4 py-2 bg-green-600 text-white font-semibold rounded-lg hover:bg-green-700 hover:-translate-y-0.5 hover:shadow-lg hover:shadow-green-600/30 transition-all no-underline">
            <span>View Summary</span>
        </a>
        
        <button onclick="showPdfOrganizer()"
                class="inline-flex items-center gap-2 px-4 py-2 bg-orange-600 text-white font-semibold rounded-lg hover:bg-orange-700 hover:-translate-y-0.5 hover:shadow-lg hover:shadow-orange-600/30 transition-all">
            <span>📁 Organize PDFs</span>
        </button>

    </div>
</div>

{% for page in reshaped_data %}
<div class="mb-8 p-6 bg-gray-50 rounded-lg border-l-4 border-blue-600">
    <h3 class="text-blue-600 mb-4 flex items-center gap-2">
        <span>Page {{ page.page }}</span>
    </h3>

    {% for section in page.sections %}
        {% include 'tax_extractor/partials/section_display.html' %}
    {% endfor %}
</div>
{% endfor %}

</div>

<!-- Custom Fields Section -->
<div class="mt-6 p-4 bg-yellow-50 border-l-4 border-yellow-600 rounded-lg">
    <h3 class="text-yellow-600 text-lg font-semibold mb-4">Custom Requirements</h3>
    
    {% if extracted_data.custom_fields %}
    <ul class="space-y-2 mb-4">
        {% for item in extracted_data.custom_fields %}
            <li class="text-gray-700 bg-white p-2 rounded border flex justify-between items-center">
                <span><strong>{{ item.name }}:</strong> {{ item.value }}</span>
                <button onclick="deleteCustomField({{ forloop.counter0 }})" 
                        class="text-red-600 hover:text-red-800 text-sm px-2 py-1 rounded hover:bg-red-50">
                    ✕
                </button>
            </li>
        {% endfor %}
    </ul>
    {% endif %}
    
    <!-- Add Custom Field Form -->
    <div class="bg-white p-4 rounded border border-yellow-300">
        <h4 class="text-sm font-semibold text-gray-700 mb-3">Add Missing Requirement</h4>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
            <input type="text" id="customFieldName" placeholder="Requirement name" 
                   class="px-3 py-2 border border-gray-300 rounded focus:outline-none focus:border-yellow-500">
            <input type="text" id="customFieldValue" placeholder="Description/Value" 
                   class="px-3 py-2 border border-gray-300 rounded focus:outline-none focus:border-yellow-500">
            <button onclick="addCustomField()" 
                    class="px-4 py-2 bg-yellow-600 text-white rounded hover:bg-yellow-700 transition-colors">
                Add Field
            </button>
        </div>
        <div id="customFieldStatus" class="mt-2 hidden"></div>
    </div>
</div>

<!-- Activity Log Accordion -->
<div class="mt-8 bg-white rounded-lg shadow-lg overflow-hidden border border-gray-200">
    <button onclick="toggleActivityLog()" 
            class="w-full px-6 py-4 bg-gradient-to-r from-gray-50 to-gray-100 hover:from-gray-100 hover:to-gray-200 transition-all flex justify-between items-center">
        <div class="flex items-center gap-3">
            <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
            </svg>
            <h3 class="text-lg font-semibold text-gray-800">Activity Log</h3>
            <span class="text-sm text-gray-500">({{ activity_logs|length }} recent activities)</span>
        </div>
        <svg id="activityLogIcon" class="w-5 h-5 text-gray-600 transform transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
        </svg>
    </button>
    
    <div id="activityLogContent" class="hidden">
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-100">
                    <tr>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">Timestamp</th>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">User</th>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">Action</th>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">Description</th>
                    </tr>
                </thead>
                <tbody class="bg-white divide-y divide-gray-200">
                    {% if activity_logs %}
                        {% for log in activity_logs %}
                        <tr class="hover:bg-blue-50 transition-colors">
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600">
                                {{ log.timestamp|date:"M d, Y H:i" }}
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-700 font-medium">
                                {{ log.user.username|default:"System" }}
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <span class="px-3 py-1 inline-flex text-xs leading-5 font-semibold rounded-full 
                                    {% if log.action == 'document_upload' %}bg-blue-100 text-blue-800
                                    {% elif log.action == 'email_sent' %}bg-green-100 text-green-800
                                    {% else %}bg-gray-100 text-gray-800{% endif %}">
                                    {{ log.get_action_display }}
                                </span>
                            </td>
                            <td class="px-6 py-4 text-sm text-gray-600">{{ log.description }}</td>
                        </tr>
                        {% endfor %}
                    {% else %}
                        <tr>
                            <td colspan="5" class="px-6 py-8 text-center">
                                <div class="text-gray-400">
                                    <svg class="mx-auto h-12 w-12 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                                    </svg>
                                    <p class="text-sm">No activity logs available for this document</p>
                                </div>
                            </td>
                        </tr>
                    {% endif %}
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="text-center mt-8">
    <a href="{% url 'document_list' %}" class="inline-flex items-center gap-2 px-6 py-3 bg-white text-blue-600 border-2 border-blue-600 font-semibold rounded-lg hover:bg-blue-50 transition-all no-underline">
        <span>Back to Documents</span>
    </a>
</div>

<!-- Email Modal -->
<div id="emailModal" class="fixed inset-0 bg-black/50 z-50 hidden items-center justify-center">
    <div class="bg-white p-8 rounded-xl max-w-md w-11/12 shadow-2xl">
        <h3 class="mb-6 text-gray-800 text-xl font-semibold">Send Tax Report via Email</h3>
        <div class="mb-6">
            <label class="block mb-2 font-semibold text-gray-800" for="recipientEmail">Recipient Email Address</label>
            <input type="email" id="recipientEmail" class="w-full px-3 py-3 border-2 border-gray-200 rounded-lg text-base focus:outline-none focus:border-blue-600 focus:ring-3 focus:ring-blue-100 transition-all" placeholder="Enter email address" value="{{ user.email }}" required>
        </div>
        <div id="emailStatus" class="my-4 hidden"></div>
        <div class="flex gap-3 mt-6">
            <button onclick="sendEmail()" class="flex-1 inline-flex items-center justify-center gap-2 px-6 py-3 bg-blue-600 text-white font-semibold rounded-lg hover:bg-blue-700 hover:-translate-y-0.5 hover:shadow-lg hover:shadow-blue-600/30 transition-all" id="sendBtn">
                <span>Send Email</span>
            </button>
            <button onclick="closeEmailModal()" class="flex-1 inline-flex items-center justify-center gap-2 px-6 py-3 bg-white text-blue-600 border-2 border-blue-600 font-semibold rounded-lg hover:bg-blue-50 transition-all">
                <span>Cancel</span>
            </button>
        </div>
    </div>
</div>

<!-- PDF Organizer Modal -->
<div id="pdfOrganizerModal" class="fixed inset-0 bg-black/50 z-50 hidden items-center justify-center">
    <div class="bg-white p-8 rounded-xl max-w-4xl w-11/12 max-h-[90vh] overflow-y-auto shadow-2xl">
        <div class="flex justify-between items-center mb-6">
            <h3 class="text-xl font-semibold text-gray-800">Organize PDFs - {{ taxpayer_name }}</h3>
            <button onclick="closePdfOrganizer()" class="text-gray-500 hover:text-gray-700">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
            </button>
        </div>
        
        <div class="grid md:grid-cols-2 gap-6">
            <!-- Unsorted PDFs -->
            <div class="bg-yellow-50 p-4 rounded-lg border">
                <h4 class="font-semibold text-yellow-800 mb-3 flex items-center gap-2">
                    <span>📄</span> Unsorted PDFs
                </h4>
                <div id="unsortedPdfs" class="space-y-2 max-h-64 overflow-y-auto">
                    <div class="text-gray-500 text-center py-4">Loading...</div>
                </div>
            </div>
            
            <!-- Sorted PDFs -->
            <div class="bg-green-50 p-4 rounded-lg border">
                <h4 class="font-semibold text-green-800 mb-3 flex items-center gap-2">
                    <span>✅</span> Sorted PDFs
                </h4>
                <div id="sortedPdfs" class="space-y-2 max-h-64 overflow-y-auto">
                    <div class="text-gray-500 text-center py-4">Loading...</div>
                </div>
            </div>
        </div>
        
        <div id="pdfOrganizerStatus" class="mt-4 hidden"></div>
        
        <div class="flex justify-end gap-3 mt-6">
            <button onclick="refreshPdfLists()" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700">
                🔄 Refresh
            </button>
            <button onclick="closePdfOrganizer()" class="px-4 py-2 bg-gray-600 text-white rounded-lg hover:bg-gray-700">
                Close
            </button>
        </div>
    </div>
</div>

<script>
function getCookie(name) {
    let cookieValue = null;
    if (document.cookie && document.cookie !== '') {
        const cookies = document.cookie.split(';');
        for (let i = 0; i < cookies.length; i++) {
            const cookie = cookies[i].trim();
            if (cookie.substring(0, name.length + 1) === (name + '=')) {
                cookieValue = decodeURIComponent(cookie.substring(name.length + 1));
                break;
            }
        }
    }
    return cookieValue;
}

function showEmailModal() {
    document.getElementById('emailModal').classList.remove('hidden');
    document.getElementById('emailModal').classList.add('flex');
}

function closeEmailModal() {
    document.getElementById('emailModal').classList.add('hidden');
    document.getElementById('emailModal').classList.remove('flex');
    document.getElementById('emailStatus').classList.add('hidden');
}

function showStatus(message, isSuccess) {
    const statusDiv = document.getElementById('emailStatus');
    statusDiv.classList.remove('hidden');
    statusDiv.className = isSuccess ? 'bg-green-50 border-l-4 border-green-500 p-4 flex items-center gap-3' : 'bg-red-50 border-l-4 border-red-500 p-4 flex items-center gap-3';
    statusDiv.innerHTML = `<div><strong class="${isSuccess ? 'text-green-800' : 'text-red-800'}">${message}</strong></div>`;
}

async function sendEmail() {
    const email = document.getElementById('recipientEmail').value;
    if (!email || !email.includes('@')) {
        showStatus('Please enter a valid email address', false);
        return;
    }

    const sendBtn = document.getElementById('sendBtn');
    sendBtn.disabled = true;
    sendBtn.innerHTML = '<span>Sending...</span>';

    try {
        const response = await fetch('{% url "send_email" document.id %}', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-CSRFToken': getCookie('csrftoken')
            },
            body: JSON.stringify({ email: email })
        });
        
        const data = await response.json();
        if (data.success) {
            showStatus(data.message, true);
            setTimeout(closeEmailModal, 2000);
        } else {
            showStatus(data.error || 'Failed to send email', false);
        }
    } catch (error) {
        showStatus('Network error: ' + error.message, false);
    } finally {
        sendBtn.disabled = false;
        sendBtn.innerHTML = '<span>Send Email</span>';
    }
}

// Add this function to the existing <script> tag at the bottom
function toggleActivityLog() {
    const content = document.getElementById('activityLogContent');
    const icon = document.getElementById('activityLogIcon');
    
    content.classList.toggle('hidden');
    icon.classList.toggle('rotate-180');
}

document.getElementById('emailModal').addEventListener('click', function(e) {
    if (e.target === this) closeEmailModal();
});

document.getElementById('pdfOrganizerModal').addEventListener('click', function(e) {
    if (e.target === this) closePdfOrganizer();
});

document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') {
        closeEmailModal();
        closePdfOrganizer();
    }
});

// Custom Field Functions
function showCustomFieldStatus(message, isSuccess) {
    const statusDiv = document.getElementById('customFieldStatus');
    statusDiv.classList.remove('hidden');
    statusDiv.className = isSuccess ? 'mt-2 p-2 bg-green-100 text-green-800 rounded text-sm' : 'mt-2 p-2 bg-red-100 text-red-800 rounded text-sm';
    statusDiv.textContent = message;
    
    setTimeout(() => {
        statusDiv.classList.add('hidden');
    }, 3000);
}

async function addCustomField() {
    const fieldName = document.getElementById('customFieldName').value.trim();
    const fieldValue = document.getElementById('customFieldValue').value.trim();
    
    if (!fieldName || !fieldValue) {
        showCustomFieldStatus('Please fill in both field name and value', false);
        return;
    }
    
    try {
        const response = await fetch('{% url "add_custom_field" document.id %}', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-CSRFToken': getCookie('csrftoken')
            },
            body: JSON.stringify({
                field_name: fieldName,
                field_value: fieldValue
            })
        });
        
        const data = await response.json();
        if (data.success) {
            showCustomFieldStatus('Custom field added successfully!', true);
            // Clear the form
            document.getElementById('customFieldName').value = '';
            document.getElementById('customFieldValue').value = '';
            // Reload page to show the new field
            setTimeout(() => location.reload(), 1500);
        } else {
            showCustomFieldStatus(data.error || 'Failed to add custom field', false);
        }
    } catch (error) {
        showCustomFieldStatus('Network error: ' + error.message, false);
    }
}

// Allow Enter key to submit custom field
document.getElementById('customFieldName').addEventListener('keypress', function(e) {
    if (e.key === 'Enter') addCustomField();
});
document.getElementById('customFieldValue').addEventListener('keypress', function(e) {
    if (e.key === 'Enter') addCustomField();
});

// Delete custom field function
async function deleteCustomField(fieldIndex) {
    if (!confirm('Are you sure you want to delete this custom field?')) {
        return;
    }
    
    try {
        const response = await fetch('{% url "delete_custom_field" document.id %}', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-CSRFToken': getCookie('csrftoken')
            },
            body: JSON.stringify({
                field_index: fieldIndex
            })
        });
        
        const data = await response.json();
        if (data.success) {
            showCustomFieldStatus('Custom field deleted successfully!', true);
            setTimeout(() => location.reload(), 1000);
        } else {
            showCustomFieldStatus(data.error || 'Failed to delete custom field', false);
        }
    } catch (error) {
        showCustomFieldStatus('Network error: ' + error.message, false);
    }
}

// PDF Organizer Functions
function showPdfOrganizer() {
    const taxpayerName = '{{ taxpayer_name|escapejs }}';
    if (!taxpayerName || taxpayerName === '[Missing Taxpayer Info]') {
        alert('Cannot organize PDFs: Taxpayer name not found');
        return;
    }
    
    document.getElementById('pdfOrganizerModal').classList.remove('hidden');
    document.getElementById('pdfOrganizerModal').classList.add('flex');
    loadPdfLists();
}

function closePdfOrganizer() {
    document.getElementById('pdfOrganizerModal').classList.add('hidden');
    document.getElementById('pdfOrganizerModal').classList.remove('flex');
}

function showPdfStatus(message, isSuccess) {
    const statusDiv = document.getElementById('pdfOrganizerStatus');
    statusDiv.classList.remove('hidden');
    statusDiv.className = isSuccess ? 
        'mt-4 p-3 bg-green-50 border-l-4 border-green-500 text-green-800' : 
        'mt-4 p-3 bg-red-50 border-l-4 border-red-500 text-red-800';
    statusDiv.textContent = message;
    setTimeout(() => statusDiv.classList.add('hidden'), 3000);
}

async function loadPdfLists() {
    const taxpayerName = '{{ taxpayer_name|escapejs }}';
    try {
        const response = await fetch(`{% url 'get_pdf_lists' 'PLACEHOLDER' %}`.replace('PLACEHOLDER', encodeURIComponent(taxpayerName)));
        const data = await response.json();
        
        if (data.success) {
            displayPdfList('unsortedPdfs', data.unsorted_pdfs, 'unsorted');
            displayPdfList('sortedPdfs', data.sorted_pdfs, 'sorted');
        } else {
            showPdfStatus(data.error || 'Failed to load PDF lists', false);
        }
    } catch (error) {
        showPdfStatus('Network error: ' + error.message, false);
    }
}

function displayPdfList(containerId, pdfs, folderType) {
    const container = document.getElementById(containerId);
    
    if (!pdfs || pdfs.length === 0) {
        container.innerHTML = '<div class="text-gray-500 text-center py-4">No PDFs found</div>';
        return;
    }
    
    container.innerHTML = pdfs.map(pdf => `
        <div class="bg-white p-3 rounded border flex justify-between items-center">
            <div class="flex-1">
                <div class="font-medium text-sm">${pdf.filename}</div>
                <div class="text-xs text-gray-500">${formatFileSize(pdf.size)} • ${formatDate(pdf.modified)}</div>
            </div>
            <button onclick="movePdf('${pdf.filename}', '${folderType}', '${folderType === 'sorted' ? 'unsorted' : 'sorted'}')"
                    class="px-3 py-1 text-xs rounded ${
                        folderType === 'sorted' ? 
                        'bg-yellow-100 text-yellow-800 hover:bg-yellow-200' : 
                        'bg-green-100 text-green-800 hover:bg-green-200'
                    }">
                ${folderType === 'sorted' ? '← Unsort' : 'Sort →'}
            </button>
        </div>
    `).join('');
}

async function movePdf(filename, fromFolder, toFolder) {
    const taxpayerName = '{{ taxpayer_name|escapejs }}';
    
    let formType = null;
    if (toFolder === 'sorted') {
        formType = await showFormTypeSelector();
        if (!formType) return; // User cancelled
    }
    
    try {
        const response = await fetch('{% url "move_pdf" %}', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-CSRFToken': getCookie('csrftoken')
            },
            body: JSON.stringify({
                filename: filename,
                from_folder: fromFolder,
                to_folder: toFolder,
                taxpayer_name: taxpayerName,
                form_type: formType
            })
        });
        
        const data = await response.json();
        if (data.success) {
            showPdfStatus(data.message, true);
            loadPdfLists(); // Refresh the lists
        } else {
            showPdfStatus(data.error || 'Failed to move PDF', false);
        }
    } catch (error) {
        showPdfStatus('Network error: ' + error.message, false);
    }
}

async function showFormTypeSelector() {
    const taxpayerName = '{{ taxpayer_name|escapejs }}';
    
    // Get required forms for this client
    let formTypes = [];
    try {
        const response = await fetch(`{% url 'get_client_required_forms' 'PLACEHOLDER' %}`.replace('PLACEHOLDER', encodeURIComponent(taxpayerName)));
        const data = await response.json();
        
        if (data.success && data.form_types.length > 0) {
            formTypes = data.form_types;
        } else {
            // Fallback to default forms if no required forms found
            formTypes = [
                {value: 'W-2', display: 'W-2'},
                {value: '1099-INT', display: '1099-INT'},
                {value: '1099-B', display: '1099-B'},
                {value: '1099-DIV', display: '1099-DIV'},
                {value: '1099-R', display: '1099-R'},
                {value: '5498', display: '5498'},
                {value: 'SSA-1099', display: 'SSA-1099'},
                {value: '8949', display: '8949'},
                {value: '1099-NEC', display: '1099-NEC'},
                {value: '1099-MISC', display: '1099-MISC'},
                {value: '1099-K', display: '1099-K'},
                {value: '1098', display: '1098'},
                {value: '1098-T', display: '1098-T'},
                {value: '1098-E', display: '1098-E'},
                {value: '1099-Q', display: '1099-Q'}
            ];
        }
    } catch (error) {
        // Fallback to default forms on error
        formTypes = [
            {value: 'W-2', display: 'W-2'},
            {value: '1099-INT', display: '1099-INT'},
            {value: '1099-B', display: '1099-B'},
            {value: '1099-DIV', display: '1099-DIV'},
            {value: '1099-R', display: '1099-R'},
            {value: '5498', display: '5498'},
            {value: 'SSA-1099', display: 'SSA-1099'},
            {value: '8949', display: '8949'},
            {value: '1099-NEC', display: '1099-NEC'},
            {value: '1099-MISC', display: '1099-MISC'},
            {value: '1099-K', display: '1099-K'},
            {value: '1098', display: '1098'},
            {value: '1098-T', display: '1098-T'},
            {value: '1098-E', display: '1098-E'},
            {value: '1099-Q', display: '1099-Q'}
        ];
    }
    
    return new Promise((resolve) => {
        const modal = document.createElement('div');
        modal.className = 'fixed inset-0 bg-black/50 z-[60] flex items-center justify-center';
        modal.innerHTML = `
            <div class="bg-white p-6 rounded-lg shadow-xl max-w-sm w-11/12">
                <h4 class="font-semibold mb-2">Select Form Type</h4>
                <p class="text-sm text-gray-600 mb-4">Forms based on client's required documents</p>
                <select id="formTypeSelect" class="w-full p-2 border rounded mb-4">
                    <option value="">Choose form type...</option>
                    ${formTypes.map(type => `<option value="${typeof type === 'object' ? type.value : type}">${typeof type === 'object' ? type.display : type}</option>`).join('')}
                </select>
                <div class="flex gap-2">
                    <button onclick="confirmFormType()" class="flex-1 bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700">Confirm</button>
                    <button onclick="cancelFormType()" class="flex-1 bg-gray-600 text-white px-4 py-2 rounded hover:bg-gray-700">Cancel</button>
                </div>
            </div>
        `;
        
        document.body.appendChild(modal);
        
        window.confirmFormType = () => {
            const selected = document.getElementById('formTypeSelect').value;
            document.body.removeChild(modal);
            delete window.confirmFormType;
            delete window.cancelFormType;
            resolve(selected || null);
        };
        
        window.cancelFormType = () => {
            document.body.removeChild(modal);
            delete window.confirmFormType;
            delete window.cancelFormType;
            resolve(null);
        };
    });
}

function refreshPdfLists() {
    loadPdfLists();
}

function formatFileSize(bytes) {
    if (bytes === 0) return '0 B';
    const k = 1024;
    const sizes = ['B', 'KB', 'MB'];
    const i = Math.floor(Math.log(bytes) / Math.log(k));
    return parseFloat((bytes / Math.pow(k, i)).toFixed(1)) + ' ' + sizes[i];
}

function formatDate(dateString) {
    return new Date(dateString).toLocaleDateString();
}
</script>

{% endblock %}